# Gemini API key (Gemini 2.5 Pro reasoning). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Google Maps Platform key (Places API New, Maps JavaScript, Geocoding, Photorealistic 3D tiles).
# Use your OWN key with BILLING ENABLED to avoid the shared demo key's low daily Places quota.
# Create at https://console.cloud.google.com/google/maps-apis/credentials
MAPS_API_KEY=your-maps-key-here
