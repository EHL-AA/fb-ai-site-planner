# Gemini API key (Gemini 2.5 Pro reasoning). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# Google Maps Platform key (Places API New, Maps JavaScript, Geocoding, Photorealistic 3D tiles).
# Use your OWN key with BILLING ENABLED to avoid the shared demo key's low daily Places quota.
# Create at https://console.cloud.google.com/google/maps-apis/credentials
MAPS_API_KEY=your-maps-key-here

# Firebase Authentication config (login screen). Copy these from your Firebase
# project's web app: Project settings → General → Your apps → SDK setup & config.
# Enable the Google and Email/Password providers under Authentication → Sign-in method.
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
